---
/**
 * EON · Landing one-page (long scroll)
 * Compone todas las secciones en orden:
 *   Header → Hero → Marquee → Video → Venue → Partners → Reservas → Dirección → Footer
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import VenueVideo from "../components/VenueVideo.astro";
import VenueSection from "../components/VenueSection.astro";
import Partners from "../components/Partners.astro";
import Location from "../components/Location.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout>
  <Header />
  <main>
    <Hero />
    <Marquee />
    <VenueVideo />
    <VenueSection />
    <Partners />
    <Location />
  </main>
  <Footer />
</BaseLayout>
