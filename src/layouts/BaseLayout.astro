---
/**
 * BaseLayout · estructura común para todas las páginas.
 *  - <head> con SEO completo (meta, OG, Twitter, JSON-LD LocalBusiness)
 *  - Fuentes Google (preconnect + display=swap para no bloquear render)
 *  - Estilos globales
 *  - Slot para el contenido
 *  - Scripts de cursor + scroll-reveal cargados al final con type=module
 */
import "../styles/global.css";
import { site } from "../data/site";
import CustomCursor from "../components/CustomCursor.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = `${site.name} · ${site.tagline}`,
  description = site.description,
  ogImage = site.ogImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).toString();
const ogImageUrl = new URL(ogImage, Astro.site ?? site.url).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "EntertainmentBusiness",
  name: site.name,
  description: site.description,
  url: site.url,
  email: site.email,
  telephone: site.phone,
  image: ogImageUrl,
  sameAs: [site.socials.instagram, site.socials.x],
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressCountry: site.address.country,
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: site.address.lat,
    longitude: site.address.lng,
  },
};
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000000" />
    <meta name="color-scheme" content="dark" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {/* Favicon (placeholder — reemplazar) */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* Fuentes (placeholder hasta tener la oficial) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Orbitron:wght@500;700;900&display=swap"
    />

    {/* JSON-LD para Google */}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {/* Skip intro si ya se mostró en esta sesión.
        Inline + síncrono: corre antes del primer paint para que el overlay
        ni siquiera se vea cuando navegás entre páginas. */}
    <script is:inline>
      try {
        if (sessionStorage.getItem("eon_intro_played")) {
          document.documentElement.classList.add("intro-skip");
        } else {
          sessionStorage.setItem("eon_intro_played", "1");
        }
      } catch (e) { /* sessionStorage puede fallar en modos privados */ }
    </script>
  </head>

  <body>
    <CustomCursor />

    {/* Overlay de intro · se autoremueve por CSS (animation-fill-mode forwards) */}
    <div class="page-intro" aria-hidden="true">
      <span class="page-intro__brand">EON</span>
    </div>

    <slot />

    {/* Scripts deferred — son módulos, no bloquean render */}
    <script type="module" src="/scripts/cursor.js"></script>
    <script type="module" src="/scripts/scroll-reveal.js"></script>
  </body>
</html>

<style is:global>
  /* --- Page intro overlay ----------------------------------- */
  .page-intro {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: var(--c-bg);
    display: grid;
    place-items: center;
    pointer-events: none;
    animation: page-intro-out 0.55s var(--ease-out) 0.95s forwards;
  }
  .page-intro__brand {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3.5rem, 14vw, 9rem);
    background: var(--grad-brand);
    -webkit-background-clip: text;
            background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    letter-spacing: 0.08em;
    filter: drop-shadow(0 0 24px rgba(232, 60, 200, 0.35));
    animation: page-intro-brand 1.0s var(--ease-out) both;
  }
  @keyframes page-intro-brand {
    0%   { opacity: 0; letter-spacing: 0.4em;  filter: blur(14px) drop-shadow(0 0 0 transparent); transform: scale(0.85); }
    55%  { opacity: 1; letter-spacing: 0.1em;  filter: blur(0)    drop-shadow(0 0 32px rgba(232, 60, 200, 0.55)); transform: scale(1); }
    100% { opacity: 1; letter-spacing: 0.08em; filter: blur(0)    drop-shadow(0 0 24px rgba(232, 60, 200, 0.35)); transform: scale(1); }
  }
  @keyframes page-intro-out {
    0%   { opacity: 1; }
    100% { opacity: 0; visibility: hidden; }
  }

  /* Si la intro ya se mostró en esta sesión, no la rendereamos */
  html.intro-skip .page-intro { display: none !important; }

  /* Reduced motion: sin intro */
  @media (prefers-reduced-motion: reduce) {
    .page-intro { display: none !important; }
  }
</style>
