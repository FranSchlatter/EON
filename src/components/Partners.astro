---
/**
 * Partners · slider auto-scrolling (mismo patrón que el marquee de eventos,
 * pero más lento y con logos en vez de texto).
 * Duplicamos la lista para conseguir un loop perfecto.
 */
import { partners } from "../data/partners";

/* El marquee necesita un track suficientemente largo para que siempre
   se vean varios logos a la vez. Repetimos la lista varias veces y
   después duplicamos el total — esa duplicación final es la que
   permite el loop seamless con translateX(-50%). */
const REPEAT = Math.max(1, Math.ceil(8 / partners.length));
const baseLoop = Array.from({ length: REPEAT }, () => partners).flat();
const loopItems = [...baseLoop, ...baseLoop];
---

<section class="partners section" id="partners">
  <div class="container">
    <header class="partners__header reveal">
      <p class="eyebrow">— Partners</p>
      <h2 class="partners__title">
        Construido junto a <span class="gradient-text">los mejores</span>.
      </h2>
    </header>
  </div>

  <div class="marquee partners__marquee" aria-label="Partners de EON">
    <ul class="marquee__track partners__track" role="list">
      {loopItems.map((p, i) => (
        <li class="partners__item" aria-hidden={i >= partners.length ? "true" : undefined}>
          {p.href ? (
            <a href={p.href} target="_blank" rel="noopener" aria-label={p.name}>
              <img src={p.logo} alt={p.name} loading="lazy" />
            </a>
          ) : (
            <img src={p.logo} alt={p.name} loading="lazy" />
          )}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .partners__header { max-width: 720px; margin-bottom: var(--space-7); }
  .partners__title { font-size: var(--fs-2xl); }

  /* El wrapper toma el padding vertical (no el track), así no se
     desincroniza el loop del marquee.
     gap: 0 → los recuadros quedan pegados (sin separación). */
  .partners__marquee {
    --marquee-gap: 0px;
    padding-block: var(--space-5);
  }
  .partners__marquee .marquee__track {
    animation-duration: 45s;
  }

  .partners__track {
    list-style: none;
  }

  /* Cada logo va dentro de su recuadro: solo borde, sin relleno.
     margin-left: -1px colapsa el borde con el del recuadro anterior,
     así comparten una única línea fina (sin separación ni doble grosor). */
  .partners__item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--c-border);
    background: transparent;
    padding: var(--space-4) var(--space-6);
    margin-left: -1px;
    transition: border-color var(--dur-base) var(--ease-out);
  }
  .partners__item:hover {
    border-color: var(--c-neon-cyan);
  }
  .partners__item > a {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .partners__item img {
    height: 140px;
    width: auto;
    max-width: none;
    object-fit: contain;
    display: block;
    opacity: 0.85;
    transition: opacity var(--dur-base) var(--ease-out);
  }
  .partners__item:hover img { opacity: 1; }

  @media (max-width: 720px) {
    .partners__item img { height: 100px; }
    .partners__item { padding: var(--space-3) var(--space-5); }
    .partners__marquee .marquee__track { animation-duration: 35s; }
  }
</style>
