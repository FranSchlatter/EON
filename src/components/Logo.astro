---
/**
 * Logo · imagen oficial EON (incluye wordmark + "Play the Future").
 */
interface Props {
  size?: "sm" | "md" | "lg";
  href?: string | null;
}
const { size = "md", href = "#top" } = Astro.props;

// Alto del logo por tamaño (el ancho se calcula solo, ratio ~2.18:1).
const sizeMap: Record<string, string> = {
  sm: "1.75rem",
  md: "2.5rem",
  lg: "3.5rem",
};
const logoHeight = sizeMap[size];

const Wrapper = href ? "a" : "div";
---

<Wrapper
  class="logo"
  {...(href ? { href, "aria-label": "EON · ir al inicio" } : {})}
  style={`--logo-height: ${logoHeight}`}
>
  <img
    src="/images/EON_Logo.png"
    alt="EON · Play the Future"
    class="logo__img"
    width="436"
    height="200"
  />
</Wrapper>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    line-height: 1;
    text-decoration: none;
    transition: filter var(--dur-base) var(--ease-out);
  }
  .logo:hover { filter: drop-shadow(0 0 12px rgba(232, 60, 200, 0.5)); }

  .logo__img {
    height: var(--logo-height);
    width: auto;
    display: block;
  }
</style>
