---
/**
 * Header · fijo, blur. Layout: logo a la izquierda, todo lo demás
 * (nav + redes + CTA reserva) agrupado a la derecha.
 * En mobile el nav colapsa a un menú hamburguesa controlado por checkbox.
 */
import Logo from "./Logo.astro";
import { navLinks } from "../data/nav";
import { site } from "../data/site";
---

<header class="site-header" id="top">
  <div class="container site-header__inner">
    <Logo size="md" href="/" />

    {/* Toggle CSS-only para mobile */}
    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-burger" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </label>

    <div class="site-header__right">
      <nav class="site-nav" aria-label="Principal">
        <ul class="site-nav__list">
          {navLinks.map((l) => (
            <li><a class="nav-link" href={l.href}>{l.label}</a></li>
          ))}
          <li class="site-nav__socials">
            <a class="social-icon" href={site.socials.instagram} target="_blank" rel="noopener" aria-label="Instagram de EON">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
            <a class="social-icon" href={site.socials.x} target="_blank" rel="noopener" aria-label="X de EON">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/>
              </svg>
            </a>
            <a class="social-icon" href={site.socials.discord} target="_blank" rel="noopener" aria-label="Discord de EON">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
              </svg>
            </a>
          </li>
          <li class="site-nav__cta-mobile">
            <a class="btn-reserva" href="/reservas">Reserva</a>
          </li>
        </ul>
      </nav>

      <a class="btn-reserva site-header__cta" href="/reservas">Reserva</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: var(--z-header);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.72), rgba(0, 0, 0, 0.45));
    border-bottom: 1px solid var(--c-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    min-height: 72px;
  }

  /* Grupo derecha: nav + CTA pegados */
  .site-header__right {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    margin-left: auto;
  }

  /* --- Nav desktop --- */
  .site-nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    list-style: none;
  }
  .site-nav__cta-mobile { display: none; }

  /* Íconos de redes */
  .site-nav__socials {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--c-fg-muted);
    transition: color var(--dur-fast) var(--ease-out),
                transform var(--dur-fast) var(--ease-out);
  }
  .social-icon:hover {
    color: var(--c-neon-cyan);
    transform: translateY(-1px);
  }

  /* --- Toggle / burger (oculto en desktop) --- */
  .nav-toggle { display: none; }
  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px; height: 20px;
    cursor: pointer;
    z-index: 2;
  }
  .nav-burger span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--c-fg);
    border-radius: 2px;
    transition: transform var(--dur-base) var(--ease-out),
                opacity var(--dur-fast) var(--ease-out);
  }

  /* --- Mobile breakpoint --- */
  @media (max-width: 960px) {
    .site-header__cta { display: none; }
    .nav-burger { display: flex; }
    .site-nav__cta-mobile { display: block; }

    /* En mobile el wrapper deja de generar caja propia: el nav (fixed)
       y el CTA (hidden) no ocupan espacio, así Logo + burger quedan
       como únicos flex children y `space-between` los manda a los
       extremos. */
    .site-header__right {
      display: contents;
    }

    /* El header tiene backdrop-filter, lo que lo convierte en containing
       block de este panel fixed. Por eso no usamos `bottom: 0` (resolvería
       contra los 72px del header dando altura 0): fijamos la altura con
       calc respecto al viewport. */
    .site-nav {
      position: fixed;
      top: 72px;
      left: 0;
      right: 0;
      height: calc(100vh - 72px);
      height: calc(100svh - 72px);
      background: rgba(0, 0, 0, 0.94);
      backdrop-filter: blur(16px);
      transform: translateX(100%);
      transition: transform var(--dur-base) var(--ease-out);
      overflow-y: auto;
    }
    .site-nav__list {
      flex-direction: column;
      align-items: flex-start;
      padding: var(--space-7) var(--container-pad);
      gap: var(--space-5);
    }
    .nav-link { font-size: var(--fs-lg); }
    .site-nav__socials { gap: var(--space-5); margin-top: var(--space-2); }
    .social-icon svg { width: 26px; height: 26px; }

    .nav-toggle:checked ~ .site-header__right .site-nav { transform: translateX(0); }
    .nav-toggle:checked ~ .nav-burger span:nth-child(1) {
      transform: translateY(9px) rotate(45deg);
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(2) { opacity: 0; }
    .nav-toggle:checked ~ .nav-burger span:nth-child(3) {
      transform: translateY(-9px) rotate(-45deg);
    }
  }
</style>
