---
/**
 * Header · fijo, blur. Layout: logo a la izquierda, todo lo demás
 * (nav + redes + CTA reserva) agrupado a la derecha.
 * En mobile el nav colapsa a un menú hamburguesa controlado por checkbox.
 */
import Logo from "./Logo.astro";
import { navLinks } from "../data/nav";
import { site } from "../data/site";
---

<header class="site-header" id="top">
  <div class="container site-header__inner">
    <Logo size="md" href="/" />

    {/* Toggle CSS-only para mobile */}
    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-burger" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </label>

    <div class="site-header__right">
      <nav class="site-nav" aria-label="Principal">
        <ul class="site-nav__list">
          {navLinks.map((l) => (
            <li><a class="nav-link" href={l.href}>{l.label}</a></li>
          ))}
          <li>
            <a class="nav-link" href={site.socials.instagram} target="_blank" rel="noopener">
              Instagram
            </a>
          </li>
          <li>
            <a class="nav-link" href={site.socials.x} target="_blank" rel="noopener">X</a>
          </li>
          <li class="site-nav__cta-mobile">
            <a class="btn-reserva" href="/reservas">Reserva</a>
          </li>
        </ul>
      </nav>

      <a class="btn-reserva site-header__cta" href="/reservas">Reserva</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: var(--z-header);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.72), rgba(0, 0, 0, 0.45));
    border-bottom: 1px solid var(--c-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    min-height: 72px;
  }

  /* Grupo derecha: nav + CTA pegados */
  .site-header__right {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    margin-left: auto;
  }

  /* --- Nav desktop --- */
  .site-nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    list-style: none;
  }
  .site-nav__cta-mobile { display: none; }

  /* --- Toggle / burger (oculto en desktop) --- */
  .nav-toggle { display: none; }
  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px; height: 20px;
    cursor: pointer;
    z-index: 2;
  }
  .nav-burger span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--c-fg);
    border-radius: 2px;
    transition: transform var(--dur-base) var(--ease-out),
                opacity var(--dur-fast) var(--ease-out);
  }

  /* --- Mobile breakpoint --- */
  @media (max-width: 960px) {
    .site-header__cta { display: none; }
    .nav-burger { display: flex; }
    .site-nav__cta-mobile { display: block; }

    /* En mobile el wrapper deja de generar caja propia: el nav (fixed)
       y el CTA (hidden) no ocupan espacio, así Logo + burger quedan
       como únicos flex children y `space-between` los manda a los
       extremos. */
    .site-header__right {
      display: contents;
    }

    /* El header tiene backdrop-filter, lo que lo convierte en containing
       block de este panel fixed. Por eso no usamos `bottom: 0` (resolvería
       contra los 72px del header dando altura 0): fijamos la altura con
       calc respecto al viewport. */
    .site-nav {
      position: fixed;
      top: 72px;
      left: 0;
      right: 0;
      height: calc(100vh - 72px);
      height: calc(100svh - 72px);
      background: rgba(0, 0, 0, 0.94);
      backdrop-filter: blur(16px);
      transform: translateX(100%);
      transition: transform var(--dur-base) var(--ease-out);
      overflow-y: auto;
    }
    .site-nav__list {
      flex-direction: column;
      align-items: flex-start;
      padding: var(--space-7) var(--container-pad);
      gap: var(--space-5);
    }
    .nav-link { font-size: var(--fs-lg); }

    .nav-toggle:checked ~ .site-header__right .site-nav { transform: translateX(0); }
    .nav-toggle:checked ~ .nav-burger span:nth-child(1) {
      transform: translateY(9px) rotate(45deg);
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(2) { opacity: 0; }
    .nav-toggle:checked ~ .nav-burger span:nth-child(3) {
      transform: translateY(-9px) rotate(-45deg);
    }
  }
</style>
